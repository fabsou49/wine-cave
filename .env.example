# Copier ce fichier en .env et remplir les valeurs

# Clé secrète JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-moi-en-production

# Identifiants de connexion
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Port exposé (éviter 80, 443, 5000, 5001, 5002 sur Synology)
PORT=8080

# Clé API Google AI Studio — https://aistudio.google.com/app/apikey
# Optionnel : sans cette clé, le bouton "Analyser ✨" est désactivé
GEMINI_API_KEY=
