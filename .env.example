# Copier ce fichier en .env et remplir les valeurs

# Clé secrète JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-moi-en-production

# Identifiants de connexion
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Port exposé (éviter 80, 443, 5000, 5001, 5002 sur Synology)
PORT=8080

# Clé API Google AI Studio — https://aistudio.google.com/app/apikey
# Optionnel : sans cette clé, le bouton "Analyser ✨" est désactivé
GEMINI_API_KEY=

# Modèle Gemini à utiliser (défaut: gemini-2.5-flash)
# Vérifie tes quotas sur https://aistudio.google.com/app/quotas
# Options: gemini-2.5-flash (5 RPM / 20 RPD) | gemini-3.1-flash-lite (15 RPM / 500 RPD)
GEMINI_MODEL=gemini-2.5-flash
